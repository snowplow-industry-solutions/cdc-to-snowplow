{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snowplow.io/schemas/cdc-service-config.schema.json",
  "title": "CDC service config",
  "description": "Schema for the YAML config consumed by the Debezium-to-Snowplow CDC service.",
  "type": "object",
  "required": ["service", "source", "debezium", "snowplow", "tables"],
  "additionalProperties": false,
  "properties": {
    "service": {
      "type": "object",
      "required": ["app_id"],
      "additionalProperties": false,
      "properties": {
        "app_id": { "type": "string", "minLength": 1 }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "connector",
        "hostname",
        "database",
        "username",
        "password",
        "slot_name",
        "publication_name"
      ],
      "additionalProperties": false,
      "properties": {
        "connector": {
          "type": "string",
          "enum": ["postgres"]
        },
        "hostname": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "database": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "password": { "type": "string" },
        "slot_name": { "type": "string", "minLength": 1 },
        "publication_name": { "type": "string", "minLength": 1 }
      }
    },
    "debezium": {
      "type": "object",
      "required": [
        "offset_store"
      ],
      "additionalProperties": false,
      "properties": {
        "snapshot_mode": {
          "type": "string",
          "enum": [
            "never",
            "initial",
            "initial_only",
            "when_needed"
          ]
        },
        "offset_store": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "file",
                "jdbc"
              ]
            },
            "file_path": {
              "type": "string",
              "minLength": 1
            },
            "jdbc": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "username",
                "password"
              ],
              "properties": {
                "username": {
                  "type": "string",
                  "minLength": 1
                },
                "password": {
                  "type": "string",
                  "minLength": 1
                },
                "table_name": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "heartbeat_interval_ms": {
          "type": "integer",
          "minimum": 0
        },
        "publication_autocreate_mode": {
          "type": "string",
          "enum": [
            "filtered",
            "all_tables",
            "disabled"
          ]
        },
        "provide_transaction_metadata": {
          "type": "boolean"
        }
      }
    },
    "snowplow": {
      "type": "object",
      "required": ["collector_url", "cdc_source_schema"],
      "additionalProperties": false,
      "properties": {
        "collector_url": { "type": "string", "minLength": 1 },
        "cdc_source_schema": {
          "type": "string",
          "pattern": "^iglu:[^/]+/[^/]+/jsonschema/\\d+-\\d+-\\d+$"
        },
        "emitter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "batch_size": { "type": "integer", "minimum": 1, "description": "Events per HTTP request to the Snowplow collector." },
            "buffer_capacity": { "type": "integer", "minimum": 1, "description": "Maximum in-flight events. When full, emit() blocks (block-on-overflow). The service refuses to start if the wrapper does not enforce blocking." }
          }
        }
      }
    },
    "tables": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/table" }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "http": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "port": { "type": "integer", "minimum": 1, "maximum": 65535 } }
        },
        "heartbeat": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "interval_ms": { "type": "integer", "minimum": 1 } }
        }
      }
    }
  },
  "$defs": {
    "table": {
      "type": "object",
      "required": ["name", "schema", "iglu_schema", "primary_key", "columns"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "iglu_schema": {
          "type": "string",
          "pattern": "^iglu:[^/]+/[^/]+/jsonschema/\\d+-\\d+-\\d+$"
        },
        "primary_key": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "app_id": { "type": "string", "minLength": 1 },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/columnEntry" }
        }
      }
    },
    "columnEntry": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "Bare column name."
        },
        {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 1,
          "description": "Single-key map: the key is the column name, the value is a directive bag. Multiple sibling keys here usually mean a directive was under-indented one level.",
          "additionalProperties": { "$ref": "#/$defs/directiveBag" }
        }
      ]
    },
    "directiveBag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rename": { "type": "string", "minLength": 1 },
        "exclude": { "type": "boolean" },
        "transforms": {
          "type": "array",
          "items": { "$ref": "#/$defs/transformEntry" }
        }
      }
    },
    "transformEntry": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["lowercase", "uppercase", "trim", "regex_extract", "regex_replace"]
        },
        {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 1,
          "properties": {
            "regex_extract": {
              "type": "object",
              "required": ["pattern"],
              "additionalProperties": false,
              "properties": {
                "pattern": { "type": "string", "minLength": 1 },
                "group": { "type": "integer", "minimum": 0 }
              }
            },
            "regex_replace": {
              "type": "object",
              "required": ["pattern", "replacement"],
              "additionalProperties": false,
              "properties": {
                "pattern": { "type": "string", "minLength": 1 },
                "replacement": { "type": "string" }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
