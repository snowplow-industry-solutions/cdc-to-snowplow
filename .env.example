# Demo credentials for the Compose Postgres + Micro. Non-secret — safe to commit
# as an example. Copy to .env (gitignored), then load it into each terminal:
#   cp .env.example .env
#   set -a; source .env; set +a
# (Optional: `direnv` auto-loads .env on cd.)

POSTGRES_PASSWORD=cdc                 # host `run` resolves ${POSTGRES_PASSWORD}
COLLECTOR_URL=http://localhost:9090   # host `run` resolves ${COLLECTOR_URL}
PGPASSWORD=cdc                        # host `scaffold` (password is not in the URI)
